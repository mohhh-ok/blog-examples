# Copy to .env and fill in.

# --- Cartesia ---
# https://play.cartesia.ai/keys
CARTESIA_API_KEY=
# Pro Voice Cloning で作った voice の id (sk_...)
CARTESIA_VOICE_ID=
# default: sonic-3
CARTESIA_MODEL_ID=sonic-3

# --- Fish Audio ---
# https://fish.audio/go-api/
FISH_API_KEY=
# /voice-cloning で参照音声を登録すると model_id が払い出される
FISH_MODEL_ID=
# s1 / s2-pro / s1-mini  (推奨: s2-pro)
FISH_BACKEND=s2-pro

# --- Azure Personal Voice ---
# Speech Resource の key / region
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=japaneast
# /speaker_profiles で作った Personal Voice の speaker profile id
AZURE_PERSONAL_VOICE_ID=

# --- ElevenLabs (06-19 と同じ値を使う) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- CosyVoice 2 (self-host) ---
# git clone 先
COSYVOICE_ROOT=envs/CosyVoice
