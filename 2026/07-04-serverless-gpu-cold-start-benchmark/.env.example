# RunPod
RUNPOD_API_KEY=

# RunPod endpoint IDs (fire スクリプトから使う。deploy 後にセット)
RUNPOD_SDXL_ENDPOINT_ID=
RUNPOD_WHISPER_ENDPOINT_ID=

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Cloud Run URLs (deploy 後にセット)
CLOUDRUN_SDXL_URL=
CLOUDRUN_WHISPER_URL=

# (registry は Artifact Registry public に一本化したので GITHUB_USERNAME は不要)
